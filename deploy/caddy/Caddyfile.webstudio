{
  email {$LETSENCRYPT_EMAIL}
}

{$DOMAIN:localhost} {
  encode zstd gzip

  @strapi path /admin* /api* /uploads* /assets* /content-manager* /content-type-builder* /users-permissions* /upload* /i18n* /graphql* /documentation* /_health*
  handle @strapi {
    reverse_proxy strapi:1337
  }

  handle {
    reverse_proxy webstudio:3000
  }
}

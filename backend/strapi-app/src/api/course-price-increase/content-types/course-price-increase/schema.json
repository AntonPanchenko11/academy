  "attributes": {
    "name": {
      "type": "string",
      "required": true
    },
    "courses": {
      "type": "relation",
      "relation": "manyToMany",
      "target": "api::course.course",
      "inversedBy": "priceIncreases"
    },
    "effectiveAt": {
      "type": "datetime",
      "required": true
    },
    "increasePercent": {
      "type": "integer",
      "required": true,
      "min": 1
    },
    "applyToAllCourses": {
      "type": "boolean",
      "required": true,
      "default": false
    },
    "increaseState": {
      "type": "enumeration",
      "default": "scheduled",
      "enum": [
        "scheduled",
        "applied",
        "cancelled"
      ],
      "pluginOptions": {
        "content-manager": {
          "visible": false
        }
      }
    },
    "appliedAt": {
      "type": "datetime",
      "pluginOptions": {
        "content-manager": {
          "visible": false
        }
      }
    },
    "comment": {

  "options": {
    "draftAndPublish": false
  },
  "attributes": {
    "title": {
      "type": "string",
      "required": true
    },
    "slug": {
      "type": "uid",
      "targetField": "title",
      "unique": true
    },
    "publish": {
      "type": "boolean",
      "required": true,
      "default": true
    },
    "comment": {
      "type": "text"
    },
    "date": {
      "type": "date"
    },
    "waitlist": {
      "type": "boolean",
      "default": false
    },
    "courseStatus": {
      "type": "enumeration",
      "required": true,
      "default": "Идет набор",
      "enum": [
        "Идет набор",
        "Последний шанс"
      ]
    },
    "studyDays": {
      "type": "string"
    },
    "hours": {
      "type": "integer",
      "min": 0
    },
    "basePrice": {
      "type": "integer",
      "min": 0
    },
    "educationDocument": {
      "type": "enumeration",
      "enum": [
        "Диплом",
        "Удостоверение",
        "Сертификат"
      ]
    },
    "courseLink": {
      "type": "string",
      "required": true
    },
    "discount": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::discount.discount",
      "inversedBy": "courses",
      "pluginOptions": {
        "content-manager": {
          "visible": false
        }
      }
    },
    "priceIncreases": {
      "type": "relation",
      "relation": "manyToMany",
      "target": "api::course-price-increase.course-price-increase",
      "mappedBy": "courses"
    }
  }
}
